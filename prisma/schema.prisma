generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Auth / User
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// Project (案件)
// ============================================================

model Project {
  id           String   @id @default(cuid())
  code         String
  nameInternal String
  namePublic   String
  address      String?
  managerId    String
  startDate    DateTime?
  endDate      DateTime?
  totalArea    Decimal?  @db.Decimal(10, 2)
  buildingType String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  manager           User              @relation(fields: [managerId], references: [id])
  estimateRequests   EstimateRequest[]

  @@index([code])
}

// ============================================================
// Partner (協力会社)
// ============================================================

model Partner {
  id           String   @id @default(cuid())
  indexId      Int?     @unique
  partnerCode  String?  @unique
  name         String
  contactName  String?
  email        String
  email2       String?
  phone        String?
  postalCode   String?
  address      String?
  tradeTypes   String[] @default([])
  areas        String[] @default([])
  branch       Branch   @default(BOTH)
  ndaStatus    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  estimateRequests EstimateRequest[]

  @@index([email])
  @@index([partnerCode])
}

enum Branch {
  TOKYO
  OSAKA
  BOTH
}

// ============================================================
// Template (見積テンプレート)
// ============================================================

model Template {
  id        String   @id @default(cuid())
  name      String
  tradeType String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sheets           TemplateSheet[]
  estimateRequests EstimateRequest[]
}

model TemplateSheet {
  id         String @id @default(cuid())
  templateId String
  name       String
  sortOrder  Int    @default(0)

  template Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    TemplateItem[]
}

model TemplateItem {
  id          String   @id @default(cuid())
  sheetId     String
  sortOrder   Int      @default(0)
  code        String?
  name        String
  spec        String?
  quantity    Decimal? @db.Decimal(12, 2)
  unit        String?
  remarks     String?
  itemType    ItemType @default(NORMAL)

  sheet          TemplateSheet   @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  estimateItems  EstimateItem[]
}

enum ItemType {
  NORMAL
  SECTION_HEADER
  SUBTOTAL
  WELFARE
  EXPENSES
  ADJUSTMENT
}

// ============================================================
// EstimateRequest (見積依頼)
// ============================================================

model EstimateRequest {
  id            String        @id @default(cuid())
  projectId     String
  partnerId     String
  templateId    String
  token         String        @unique @db.VarChar(64)
  tokenExpiresAt DateTime
  status        RequestStatus @default(DRAFT)
  requestType   RequestType   @default(SANWA_FORMAT)
  deadline      DateTime?
  requestedAt   DateTime?
  submittedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project     Project          @relation(fields: [projectId], references: [id])
  partner     Partner          @relation(fields: [partnerId], references: [id])
  template    Template         @relation(fields: [templateId], references: [id])
  header      EstimateHeader?
  sheets      EstimateSheet[]
  attachments EstimateAttachment[]
  comments    EstimateComment[]

  @@index([token])
  @@index([projectId])
  @@index([partnerId])
}

enum RequestStatus {
  DRAFT
  REQUESTED
  IN_PROGRESS
  SUBMITTED
  CONFIRMED
  REJECTED
  RETURNED
}

enum RequestType {
  SANWA_FORMAT
  PARTNER_FORMAT
}

// ============================================================
// EstimateHeader (見積情報ヘッダー)
// ============================================================

model EstimateHeader {
  id               String  @id @default(cuid())
  estimateRequestId String @unique
  estimateNumber   String?
  date             DateTime?
  companyName      String?
  contactName      String?
  projectName      String?
  totalAmount      Int?
  netAmount        Int?
  specialNotes     String?

  estimateRequest EstimateRequest @relation(fields: [estimateRequestId], references: [id], onDelete: Cascade)
}

// ============================================================
// EstimateSheet / EstimateItem (見積明細)
// ============================================================

model EstimateSheet {
  id                String @id @default(cuid())
  estimateRequestId String
  name              String
  sortOrder         Int    @default(0)

  estimateRequest EstimateRequest @relation(fields: [estimateRequestId], references: [id], onDelete: Cascade)
  items           EstimateItem[]
}

model EstimateItem {
  id               String   @id @default(cuid())
  sheetId          String
  templateItemId   String?
  sortOrder        Int      @default(0)
  code             String?
  name             String
  spec             String?
  quantity         Decimal? @db.Decimal(12, 2)
  unit             String?
  unitPrice        Int?
  amount           Int?
  remarks          String?
  isAddedByPartner Boolean  @default(false)
  itemType         ItemType @default(NORMAL)

  sheet        EstimateSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  templateItem TemplateItem?  @relation(fields: [templateItemId], references: [id])
}

// ============================================================
// EstimateAttachment (添付ファイル)
// ============================================================

model EstimateAttachment {
  id                String @id @default(cuid())
  estimateRequestId String
  fileName          String
  fileUrl           String
  fileSize          Int?
  mimeType          String?
  uploadedBy        String?
  createdAt         DateTime @default(now())

  estimateRequest EstimateRequest @relation(fields: [estimateRequestId], references: [id], onDelete: Cascade)
}

// ============================================================
// EstimateComment (差し戻しコメント)
// ============================================================

model EstimateComment {
  id                String   @id @default(cuid())
  estimateRequestId String
  authorId          String?
  content           String
  createdAt         DateTime @default(now())

  estimateRequest EstimateRequest @relation(fields: [estimateRequestId], references: [id], onDelete: Cascade)
}
